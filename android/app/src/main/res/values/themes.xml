<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.JARVIS" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/jarvis_primary</item>
        <item name="colorPrimaryDark">@color/jarvis_bg</item>
        <item name="colorAccent">@color/jarvis_primary</item>
        <item name="android:windowBackground">@color/jarvis_bg</item>
        <item name="android:statusBarColor">@color/jarvis_bg</item>
        <item name="android:navigationBarColor">@color/jarvis_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>

    <style name="JarvisFont" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/jarvis_primary</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="JarvisLabel">
        <item name="android:textColor">@color/jarvis_text_dim</item>
        <item name="android:textSize">10sp</item>
        <item name="android:letterSpacing">0.2</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>
